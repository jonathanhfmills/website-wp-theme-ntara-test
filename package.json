{
    "name": "website-wp-theme-ntara-test",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "sass style.scss style.css --style=compressed --no-source-map && postcss style.css --replace && terser assets/js/script.js -o assets/js/script.min.js --compress --mangle",
        "watch": "chokidar 'style.scss' 'assets/**/*.scss' 'assets/js/script.js' --polling -c 'npm run build'"
    },
    "devDependencies": {
        "autoprefixer": "^10.4.21",
        "chokidar-cli": "^3.0.0",
        "postcss": "^8.5.3",
        "postcss-cli": "^11.0.1",
        "sass": "^1.86.3",
        "terser": "^5.46.1"
    }
}
